# =====================================================
# Distributed Notification System - Environment Config
# =====================================================

# --- Zookeeper ---
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# --- Kafka ---
KAFKA_BROKER_ID=1
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EXTERNAL_PORT=9092
KAFKA_REPLICATION_FACTOR=1
KAFKA_PARTITIONS=3
KAFKA_TOPICS=notifications.email,notifications.sms,notifications.push,notifications.dead-letter

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=

# --- PostgreSQL ---
POSTGRES_PORT=5432
POSTGRES_DB=notifications_db
POSTGRES_USER=notif_user
POSTGRES_PASSWORD=notif_secret

# --- Mailhog ---
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# --- Prometheus ---
PROMETHEUS_PORT=9090

# --- Grafana ---
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer

# --- Service Ports ---
API_GATEWAY_PORT=8080
NOTIFICATION_SERVICE_PORT=8081
EMAIL_SERVICE_PORT=8082
SMS_SERVICE_PORT=8083
PUSH_SERVICE_PORT=8084

# --- Application ---
SPRING_PROFILES_ACTIVE=docker
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_HOURS=1
